# ── Database ───────────────────────────────────────────────
# Render PostgreSQL internal connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── AI ──────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── AWS (optional — only needed for S3/Transcribe/SNS) ─────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
TRANSCRIBE_BUCKET=your-s3-bucket-name
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:ACCOUNT_ID:TopicName

# ── Transcription ───────────────────────────────────────────
# "false" = use Colab Whisper via COLAB_WHISPER_URL
# "true"  = use AWS Transcribe (requires S3 bucket above)
USE_AWS_TRANSCRIBE=false

# Your Colab localtunnel/ngrok URL (update each Colab session)
COLAB_WHISPER_URL=https://your-tunnel.loca.lt

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list — set to your Render frontend URL
CORS_ORIGINS=https://automated-meeting-outcome-tracker.onrender.com

# ── n8n (optional) ─────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/meeting-data
N8N_TIMEOUT=8
N8N_MAX_RETRIES=3
N8N_RETRY_DELAY=2
