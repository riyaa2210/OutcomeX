# ── Database ───────────────────────────────────────────────
# Render PostgreSQL internal connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── AI ──────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key   # optional — enables GPT-4o routing

# ── LLM Router config ────────────────────────────────────────
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600

# ── AWS (optional — only needed for S3/Transcribe/SNS) ─────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
TRANSCRIBE_BUCKET=your-s3-bucket-name
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:ACCOUNT_ID:TopicName

# ── Transcription ───────────────────────────────────────────
# "false" = use Colab Whisper via COLAB_API_URL
# "true"  = use AWS Transcribe (requires S3 bucket above)
USE_AWS_TRANSCRIBE=false

# Your Colab ngrok/localtunnel URL (update each Colab session)
# Primary key (recommended):
COLAB_API_URL=https://xxxx.ngrok-free.app
# Legacy fallback (also supported):
# COLAB_WHISPER_URL=https://xxxx.loca.lt

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list — set to your Render frontend URL
CORS_ORIGINS=https://automated-meeting-outcome-tracker.onrender.com

# ── Integrations — OAuth ────────────────────────────────────
# Google (Calendar, Meet, Tasks) — one OAuth app for all Google services
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Zoom
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_WEBHOOK_SECRET=your-zoom-webhook-secret

# Microsoft Teams (Azure AD)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=common

# Trello
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_SECRET=your-trello-api-secret

# Notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# Jira (Atlassian)
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret

# Frontend + Backend URLs (for OAuth redirect URIs)
FRONTEND_URL=https://automated-meeting-outcome-tracker.onrender.com
BACKEND_URL=https://meeting-outcome-tracker-backend.onrender.com


# Render Redis internal URL (from your Redis service)
REDIS_URL=redis://localhost:6379/0

# Flower monitoring UI credentials
FLOWER_USER=admin
FLOWER_PASSWORD=your-flower-password


# Gemini API key is reused for embeddings (text-embedding-004)
# No extra key needed — same GEMINI_API_KEY above

# pgvector is enabled via: CREATE EXTENSION IF NOT EXISTS vector;
# Run setup_pgvector.sql in pgAdmin once after deploying
# Your Activepieces flow webhook URL
# Get it from: Activepieces → your flow → Webhook trigger → copy URL
ACTIVEPIECES_WEBHOOK_URL=https://your-activepieces.com/api/v1/webhooks/YOUR_FLOW_ID

# Shared secret for HMAC-SHA256 signature verification
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ACTIVEPIECES_SECRET=your-shared-secret-here

# Retry config
AUTOMATION_TIMEOUT=10
AUTOMATION_MAX_RETRIES=3
AUTOMATION_RETRY_DELAY=2

# ── Security ────────────────────────────────────────────────
# Access token expiry (minutes) — default 15
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token expiry (days) — default 7
REFRESH_TOKEN_EXPIRE_DAYS=7
# ClamAV socket for malware scanning (optional)
# CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
