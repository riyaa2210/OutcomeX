# ── Database ──────────────────────────────────────────────────
# Render PostgreSQL connection string (auto-filled if using Render DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ───────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── AWS ────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
TRANSCRIBE_BUCKET=your-s3-bucket-name
TRANSCRIBE_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/RoleName
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:ACCOUNT_ID:TopicName

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Set to your Render frontend URL after deploying
CORS_ORIGINS=https://meettrack-frontend.onrender.com

# ── n8n ────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/meeting-data
N8N_TIMEOUT=8
N8N_MAX_RETRIES=3
N8N_RETRY_DELAY=2
